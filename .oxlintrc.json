{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "off"
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "prefer-const": "error",
    "no-var": "error",
    "no-case-declarations": "error",
    "no-empty": "error"
  },
  "options": {
    "reportUnusedDisableDirectives": "error"
  }
}
