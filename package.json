{
  "name": "opinion-front-ui",
  "version": "1.0.1",
  "type": "module",
  "description": "Opinion front-end UI - TypeScript migration from servlet-based application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "SASS_SILENCE_DEPRECATIONS=legacy-js-api vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:hotkeys": "node scripts/test-hotkeys.js",
    "lint": "oxlint src --deny-warnings",
    "lint:any": "echo 'To check explicit any usage, run: oxlint src --deny typescript/no-explicit-any'",
    "lint:fix": "oxlint src --fix"
  },
  "keywords": [
    "opinion",
    "frontend",
    "typescript",
    "migration"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@swc/core": "^1.15.46",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "oxlint": "^1.75.0",
    "sass": "^1.101.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dataloader": "^2.2.3",
    "typescript-logging": "^2.2.0",
    "typescript-logging-log4ts-style": "^2.2.0",
    "universal-router": "^10.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "jsdom": "^29.0.2",
    "test-exclude": "^8.0.0"
  }
}
